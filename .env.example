# Copy to .env and fill in values

# Emergency / testing: 6-digit code that always works (no SMS). Set in production only if you accept the risk.
MASTER_OTP=123456

# DB: sync({ alter: true }) adds missing columns when NODE_ENV is not production.
# DB_SYNC_ALTER=false
# DB_SYNC_ALTER=true

# Exact MySQL column name for the user's profile image URL (users table).
# Code default is profile_image_url. If your column is camelCase profileImageUrl, set:
# USER_PROFILE_IMAGE_DB_COLUMN=profileImageUrl

# Agora (RTC voice/video) — get App ID & Certificate from https://console.agora.io/
# Never commit real certificates; set in .env locally / server secrets.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
